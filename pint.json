{
    "preset": "laravel",
    "rules": {
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "trailing_comma_in_multiline": true,
        "single_quote": true,
        "binary_operator_spaces": {
            "default": "single_space"
        },
        "concat_space": {
            "spacing": "none"
        }
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor",
        "node_modules"
    ]
}
